# ==================== Database ====================
DB_PASSWORD=streamflow_secure_password
DATABASE_URL=postgresql://streamflow:password@postgres-master:5432/streamflow
DATABASE_REPLICA_URL=postgresql://streamflow:password@postgres-replica:5432/streamflow

# ==================== Redis ====================
REDIS_URL=redis://redis:6379

# ==================== RabbitMQ ====================
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin123

# ==================== MinIO / Object Storage ====================
MINIO_ENDPOINT=minio:9000
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin123

# ==================== JWT ====================
JWT_SECRET=change-this-to-a-very-long-secret-at-least-32-chars
JWT_EXPIRATION_HOURS=4
COOKIE_SECRET=change-this-cookie-secret

# ==================== OAuth Google ====================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback

# ==================== reCAPTCHA ====================
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# ==================== Email (for alerts) ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ==================== Environment ====================
NODE_ENV=development
PORT=8000
